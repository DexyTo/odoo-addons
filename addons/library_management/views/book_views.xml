<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_library_book_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="publication_year"/>
                <field name="pages"/>
                <field name="age_years"/>
                <field name="author_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_library_book_search" model="ir.ui.view">
        <field name="name">library.book.search</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="author_ids"/>
                <filter string="Многостраничные книги (от 500)" name="large_books" domain="[('pages', '&gt;', 500)]"/>
                <group>
                    <filter string="Год выпуска" name="group_by_year" context="{'group_by': 'publication_year'}"/>
                    <filter string="Авторы" name="group_by_author" context="{'group_by': 'author_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="publication_year"/>
                        </group>
                        <group>
                            <field name="pages"/>
                            <field name="age_years"/>
                        </group>
                    </group>
                    <group>
                        <field name="author_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Книги</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>