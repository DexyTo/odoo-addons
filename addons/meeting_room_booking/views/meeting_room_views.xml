<?xml version="1.0" encoding="utf-8"?>
<odoo>
  
    <record id="view_meeting_room_list" model="ir.ui.view">
        <field name="name">meeting.room.list</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <list string="Переговорные" decoration-muted="active == False">
                <field name="name"/>
                <field name="capacity"/>
                <field name="location_id"/>
                <field name="active_bookings_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_meeting_room_search" model="ir.ui.view">
        <field name="name">meeting.room.search</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="location_id"/>
                <field name="capacity"/>

                <filter string="Открыта" name="active" domain="[('active', '=', True)]"/>
                <filter string="Закрыта" name="inactive" domain="[('active', '=', False)]"/>

                <separator/>

                <group>
                    <filter string="Местоположение" name="group_location" context="{'group_by': 'location_id'}"/>
                    <filter string="Вместимость" name="group_capacity" context="{'group_by': 'capacity'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_meeting_room_form" model="ir.ui.view">
        <field name="name">meeting.room.form</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <form string="Переговорная комната">
                <sheet>
                    <widget name="web_ribbon" title="Закрыта" bg_color="bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="capacity"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="location_id"/>
                            <field name="active_bookings_count"/>
                        </group>
                    </group>
                    <group>
                        <field name="equipment" placeholder="Например, проектор, белая доска, телевизор..."/>
                    </group>
                    <notebook>
                        <page string="Бронирования" name="bookings">
                            <field name="booking_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="state" widget="badge" 
                                                        decoration-info="state == 'draft'"
                                                        decoration-success="state == 'active'" 
                                                        decoration-muted="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_meeting_room" model="ir.actions.act_window">
        <field name="name">Переговорные</field>
        <field name="res_model">meeting.room</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>  
    </record>

</odoo>