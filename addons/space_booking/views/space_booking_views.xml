<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_space_booking_list" model="ir.ui.view">
        <field name="name">space.booking.list</field>
        <field name="model">space.booking</field>
        <field name="arch" type="xml">
            <list string="Бронирования помещений" class="o_booking_list" 
                  decoration-success="state == 'active'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="state == 'draft'"
                  decoration-bf="state == 'active'">

                <field name="name"/>
                <field name="space_id"/>
                <field name="partner_id"/>
                <field name="start_time"/>
                <field name="end_time"/>
                <field name="duration" widget="float_time"/>

                <field name="state" widget="badge" 
                       decoration-success="state == 'active'"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_space_booking_search" model="ir.ui.view">
      <field name="name">space.booking.search</field>
      <field name="model">space.booking</field>
      <field name="arch" type="xml">
          <search>
              <field name="name" filter_domain="[('name', 'ilike', self)]"/>
              <field name="space_id"/>
              <field name="partner_id"/>

              <filter string="Мои бронирования" name="my_bookings"
                      domain="[('partner_id.user_ids', 'in', [uid])]"/>
              
              <filter string="Активные" name="active"
                      domain="[('state', '=', 'active')]"/>
              <filter string="Черновики" name="draft"
                      domain="[('state', '=', 'draft')]"/>
              
              <separator/>

              <filter string="Предстоящие" name="upcoming"
                      domain="[('start_time', '&gt;=', 'now'),
                              ('state', 'in', ['draft', 'active'])]"/>

              <filter string="Прошедшие" name="past"
                      domain="[('end_time', '&lt;', 'now')]"/>

              <separator/>
              
              <group>
                  <filter string="Помещение" name="group_space" context="{'group_by': 'space_id'}"/>
                  <filter string="Организатор" name="group_partner" context="{'group_by': 'partner_id'}"/>
                  <filter string="Статус" name="group_state" context="{'group_by': 'state'}"/>
              </group>
          </search>
      </field>
    </record>

    <record id="view_space_booking_form" model="ir.ui.view">
        <field name="name">space.booking.form</field>
        <field name="model">space.booking</field>
        <field name="arch" type="xml">
            <form string="Бронирование помещения" class="o_booking_form" edit="state not in ['done', 'cancelled']">
                <header class="o_booking_header">
                    <button name="action_confirm" 
                            string="Подтвердить" 
                            type="object" 
                            class="oe_highlight btn-confirm"
                            icon="fa-check-circle"
                            invisible="state != 'draft'"/>

                    <button name="action_done" 
                            string="Завершить" 
                            type="object"
                            class="btn-done"
                            icon="fa-flag-checkered"
                            invisible="state != 'active'"
                            groups="space_booking.group_space_booking_manager"/>

                    <button name="action_cancel" 
                            string="Отменить" 
                            type="object"
                            class="btn-cancel"
                            icon="fa-times-circle"
                            confirm="Вы уверены, что хотите отменить это бронирование?"
                            invisible="state != 'active'"/>
                    
                    <button name="action_draft" 
                            string="Черновик" 
                            type="object"
                            class="btn-draft"
                            icon="fa-undo"
                            invisible="state != 'active'"/>

                    <field name="state" widget="statusbar" class="o_booking_statusbar" 
                           statusbar_visible="draft,active,done,cancelled"/>
                </header>

                <sheet class="o_booking_sheet">
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1 class="o_booking_sheet_title">
                            <field name="name" class="o_booking_sheet_name_field" placeholder="Например, совещание..." readonly="state in ['done', 'cancelled']"/>
                        </h1>
                    </div>

                    <group class="o_booking_main_group">
                        <group string="Основная информация" class="o_booking_group_left">
                            <field name="space_id" class="o_booking_group_field" options="{'no_create': True}" placeholder="Выберите помещение" readonly="state in ['done', 'cancelled']"/>

                            <field name="partner_id" class="o_booking_group_field" string="Организатор" readonly="1"
                                   groups="!space_booking.group_space_booking_manager"/>
                            
                            <field name="partner_id" class="o_booking_group_field" string="Организатор" options="{'no_create': True, 'no_open': True}"
                                   groups="space_booking.group_space_booking_manager"
                                   readonly="state in ['done', 'cancelled']"/>

                            <field name="alarm_ids" widget="many2many_tags" placeholder="Выберите напоминания..."/>
                        </group>

                        <group string="Время проведения" class="o_booking_group_right">
                            <group class="o_booking_time_group">
                                <field name="start_time" class="o_booking_group_field" readonly="state in ['done', 'cancelled']"/>
                            </group>

                            <group class="o_booking_time_group">
                                <field name="end_time" class="o_booking_group_field" readonly="state in ['done', 'cancelled']"/>
                            </group>
                            
                            <field name="duration" class="o_booking_group_field o_duration_field" widget="float_time"/>
                        </group>
                    </group>
                    
                    <group>
                        <field name="notes" class="o_notes_field" nolabel="1"
                               placeholder="Добавьте описание встречи, повестку дня или другие важные детали..."
                               readonly="state in ['done', 'cancelled']"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_space_booking_graph" model="ir.ui.view">
        <field name="name">space.booking.graph</field>
        <field name="model">space.booking</field>
        <field name="arch" type="xml">
            <graph string="Статистика по бронированию помещений" type="bar" stacked="1">
                <field name="space_id"/>
                <field name="duration" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_space_booking_pivot" model="ir.ui.view">
        <field name="name">space.booking.pivot</field>
        <field name="model">space.booking</field>
        <field name="arch" type="xml">
            <pivot string="Анализ количества забронированных помещений">
                <field name="space_id" type="row"/>
                <field name="start_time" interval="month" type="col"/>
                <field name="duration" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_space_booking_calendar" model="ir.ui.view">
        <field name="name">space.booking.calendar</field>
        <field name="model">space.booking</field>
        <field name="arch" type="xml">
            <calendar string="Календарь бронирований" 
                      date_start="start_time" 
                      date_stop="end_time"
                      color="space_id"
                      mode="week"
                      edit="0">
                <field name="name"/>
                <field name="space_id"/>
                <field name="partner_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_space_booking" model="ir.actions.act_window">
        <field name="name">Бронирования</field>
        <field name="res_model">space.booking</field>
        <field name="view_mode">list,form,calendar,graph,pivot</field>
        <field name="context">{'search_default_upcoming': 1}</field>
    </record>

    <record id="action_my_space_bookings" model="ir.actions.act_window">
        <field name="name">Мои бронирования</field>
        <field name="res_model">space.booking</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="context">{
            'search_default_my_bookings': 1,
            'search_default_upcoming': 1,
        }</field>
    </record>

    <record id="action_space_booking_calendar" model="ir.actions.act_window">
        <field name="name">Календарь бронирования</field>
        <field name="res_model">space.booking</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>