<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_space_location_list" model="ir.ui.view">
        <field name="name">space.location.list</field>
        <field name="model">space.location</field>
        <field name="arch" type="xml">
            <list string="Местоположения">
                <field name="name"/>
                <field name="address"/>
                <field name="space_count"/>
            </list>
        </field>
    </record>

    <record id="view_space_location_search" model="ir.ui.view">
        <field name="name">space.location.search</field>
        <field name="model">space.location</field>
        <field name="arch" type="xml">
            <search string="Поиск местоположений">
                <field name="name" string="Местоположение" 
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="address"/>
            </search>
        </field>
    </record>

    <record id="view_space_location_form" model="ir.ui.view">
        <field name="name">space.location.form</field>
        <field name="model">space.location</field>
        <field name="arch" type="xml">
            <form string="Местоположение">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_spaces" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-building">
                            <field name="space_count" widget="statinfo" string="Помещения"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Например, Главное здание, этаж 3"/>
                        </h1>
                    </div>
                    <group>
                        <field name="address" placeholder="Физический адрес этого местоположения"/>
                        <field name="space_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Помещения" name="spaces">
                            <field name="space_ids" readonly="1">
                                <list string="Помещения">
                                    <field name="name"/>
                                    <field name="space_type" widget="badge"/>
                                    <field name="capacity"/>
                                    <field name="booking_count"/>
                                    <field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_space_location" model="ir.actions.act_window">
        <field name="name">Местоположения</field>
        <field name="res_model">space.location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>