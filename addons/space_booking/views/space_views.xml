<?xml version="1.0" encoding="utf-8"?>
<odoo>
  
    <record id="view_space_list" model="ir.ui.view">
        <field name="name">space.list</field>
        <field name="model">space</field>
        <field name="arch" type="xml">
            <list string="Переговорные" decoration-muted="active == False">
                <field name="name"/>
                <field name="space_type" widget="badge"/>
                <field name="capacity"/>
                <field name="location_id"/>
                <field name="booking_count"/>
                <field name="active_bookings_count" string="Активные сейчас"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_space_search" model="ir.ui.view">
        <field name="name">space.search</field>
        <field name="model">space</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" filter_domain="[('name', 'ilike', self)]"/>
                <field name="location_id"/>
                <field name="space_type"/>

                <filter string="Открыта" name="active" domain="[('active', '=', True)]"/>
                <filter string="Закрыта" name="inactive" domain="[('active', '=', False)]"/>

                <separator/>

                <filter string="Переговорные" name="meeting_rooms" 
                        domain="[('space_type', '=', 'meeting_room')]"/>
                <filter string="Коворкинги" name="coworking" 
                        domain="[('space_type', '=', 'coworking')]"/>
                <filter string="Учебные комнаты" name="classrooms" 
                        domain="[('space_type', '=', 'classroom')]"/>
                <filter string="Конференц-залы" name="conference_halls" 
                        domain="[('space_type', '=', 'conference_hall')]"/>
                <filter string="Залы для тренировок" name="training_rooms" 
                        domain="[('space_type', '=', 'training_room')]"/>
                <filter string="Помещения для проведения мероприятий" name="event_spaces" 
                        domain="[('space_type', '=', 'event_space')]"/>
                <filter string="Актовые залы" name="hall" 
                        domain="[('space_type', '=', 'hall')]"/>
                <filter string="Другие" name="other" 
                        domain="[('space_type', '=', 'other')]"/>

                <separator/>

                <group>
                    <filter string="Тип" name="group_by_type" context="{'group_by': 'space_type'}"/>
                    <filter string="Местоположение" name="group_location" context="{'group_by': 'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_space_form" model="ir.ui.view">
        <field name="name">space.form</field>
        <field name="model">space</field>
        <field name="arch" type="xml">
            <form string="Помещение">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bookings" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-check-circle">
                            <field name="active_bookings_count" widget="statinfo" string="Активные бронирования"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Закрыта" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Например, конференц-зал Альфа"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="space_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="capacity"/>
                            <field name="location_id" placeholder="Выберите местоположение"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="booking_count" readonly="1"/>
                            <field name="active_bookings_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="equipment" placeholder="Например, проектор, белая доска, телевизор..."/>
                    </group>
                    <notebook>
                        <page string="Бронирования" name="bookings">
                            <field name="booking_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                    <field name="duration" widget="float_time"/>
                                    <field name="state" widget="badge" 
                                                        decoration-info="state == 'draft'"
                                                        decoration-success="state == 'active'" 
                                                        decoration-muted="state == 'cancelled'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_space" model="ir.actions.act_window">
        <field name="name">Помещения</field>
        <field name="res_model">space</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>